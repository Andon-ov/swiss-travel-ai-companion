rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /spots/{spotId} {
      allow read: if true;
      allow write: if false; // Only admin can write spots
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /cache/{cacheId} {
      allow read: if true;
      allow write: if false; // Only functions can write cache
    }
  }
}
